{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "child": "main-content",
      "styles": {
        "background-color": "#FFFFFF"
      }
    },
    {
      "id": "main-content",
      "component": "Column",
      "children": [
        "top-row",
        "tags-row",
        "deals-row",
        "highlight-row"
      ],
      "align": "stretch",
      "styles": {
        "gap": "8px",
        "padding": "20px"
      }
    },
    {
      "id": "top-row",
      "component": "Row",
      "children": [
        "top-row_wrapper",
        "detail-button"
      ],
      "justify": "spaceBetween",
      "align": "center",
      "styles": {
        "gap": "12px"
      }
    },
    {
      "id": "top-row_wrapper",
      "component": "Row",
      "children": [
        "restaurant-image",
        "title-column"
      ],
      "align": "center",
      "styles": {
        "gap": "12px",
        "flex-shrink": 1
      }
    },
    {
      "id": "restaurant-image",
      "component": "Image",
      "url": "@placeholder(image)",
      "styles": {
        "width": "120px",
        "height": "120px",
        "border-radius": "5px"
      }
    },
    {
      "id": "title-column",
      "component": "Column",
      "children": [
        "restaurant-name",
        "rating-row"
      ],
      "align": "start",
      "styles": {
        "gap": "4px",
        "flex-shrink": 1
      }
    },
    {
      "id": "restaurant-name",
      "component": "Text",
      "text": "@placeholder(title)",
      "variant": "h3",
      "styles": {
        "font-weight": "bold",
        "color": "#333333",
        "margin": "16px 0px 0px 18px",
        "text-overflow": "ellipsis",
        "line-clamp": 1
      }
    },
    {
      "id": "rating-row",
      "component": "Row",
      "children": [
        "rating",
        "rating_dot",
        "business-hours"
      ]
    },
    {
      "id": "rating",
      "component": "Text",
      "text": "@placeholder(rating)",
      "variant": "h4",
      "styles": {
        "color": "#999999",
        "margin": "8px 0px 0px 18px",
        "line-clamp": 1
      }
    },
    {
      "id": "rating_dot",
      "component": "Text",
      "text": " · ",
      "variant": "h4",
      "styles": {
        "color": "#999999",
        "margin": "8px 0px 0px 0px",
        "line-clamp": 1
      }
    },
    {
      "id": "business-hours",
      "component": "Text",
      "text": "@placeholder(time_info)",
      "variant": "h4",
      "styles": {
        "color": "#999999",
        "margin": "8px 0px 0px 0px",
        "text-overflow": "ellipsis",
        "line-clamp": 1,
        "flex-shrink": 1
      }
    },
    {
      "id": "detail-button",
      "component": "Button",
      "child": "btn-text",
      "styles": {
        "justify": "center",
        "align": "center",
        "background-color": "#e3ebf6",
        "border-radius": "10px",
        "margin": "0px 0px 0px 18px",
        "padding": "10px 20px 10px 20px"
      }
    },
    {
      "id": "btn-text",
      "component": "Text",
      "text": "@placeholder(action_text)",
      "variant": "text",
      "styles": {
        "color": "#3c81f0",
        "font-size": "34px",
        "font-weight": "bold",
        "text-align": "center",
        "height": "34px"
      }
    },
    {
      "id": "tags-row",
      "component": "Row",
      "children": {
        "path": "@placeholder(tags)",
        "componentId": "tag"
      },
      "align": "center",
      "styles": {
        "gap": "8px"
      }
    },
    {
      "id": "tag",
      "component": "Text",
      "text": "@placeholder(tag)",
      "variant": "h4",
      "styles": {
        "background-color": "#eeeeee",
        "margin": "12px 0px 0px 6px",
        "color": "#666666"
      }
    },
    {
      "id": "deals-row",
      "component": "Row",
      "children": [
        "deal_wraper",
        "price-text"
      ],
      "align": "center",
      "justify": "spaceBetween",
      "styles": {
        "gap": "8px"
      }
    },
    {
      "id": "deal_wraper",
      "component": "Row",
      "children": [
        "deal-badge",
        "deal-text",
        "spacer"
      ],
      "align": "center",
      "styles": {
        "gap": "8px"
      }
    },
    {
      "id": "deal-badge",
      "component": "Text",
      "text": "[超值]",
      "variant": "h4",
      "styles": {
        "margin": "12px 0px 0px 6px",
        "color": "#999999"
      }
    },
    {
      "id": "deal-text",
      "component": "Text",
      "text": "@placeholder(product)",
      "variant": "h4",
      "styles": {
        "margin": "12px 0px 0px 6px",
        "color": "#999999",
        "text-overflow": "ellipsis",
        "line-clamp": 1,
        "flex-shrink": 1
      }
    },
    {
      "id": "spacer",
      "component": "Text",
      "text": "",
      "styles": {
        "weight": "1"
      }
    },
    {
      "id": "price-text",
      "component": "Text",
      "text": "@placeholder(price)",
      "variant": "h4",
      "styles": {
        "color": "#FF4D4F",
        "font-weight": "bold"
      }
    },
    {
      "id": "highlight-row",
      "component": "Row",
      "children": [
        "highlight-icon-column",
        "highlight-text",
        "highlight-text2"
      ],
      "styles": {
        "margin": "12px 0px 0px 6px",
        "padding": "8px 12px",
        "border-radius": "4px"
      }
    },
    {
      "id": "highlight-icon-column",
      "component": "Column",
      "styles": {
        "width": "30px",
        "height": "30px"
      },
      "children": [
        "hi_image"
      ]
    },
    {
      "id": "hi_image",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i4/O1CN017JNptZ1yg3vpUvGFU_!!6000000006607-2-tps-206-204.png",
      "styles": {
        "width": "30px",
        "height": "30px"
      }
    },
    {
      "id": "highlight-text",
      "component": "Text",
      "text": "亮点：",
      "variant": "h4",
      "styles": {
        "color": "#eab676",
        "line-clamp": 1
      }
    },
    {
      "id": "highlight-text2",
      "component": "Text",
      "text": "@placeholder(highlights)",
      "variant": "h4",
      "styles": {
        "color": "#eab676",
        "text-overflow": "ellipsis",
        "line-clamp": 1,
        "flex-shrink": 1
      }
    }
  ]
}