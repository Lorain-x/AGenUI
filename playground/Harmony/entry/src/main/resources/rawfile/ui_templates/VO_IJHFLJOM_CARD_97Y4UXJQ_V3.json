{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "child": "main_container"
    },
    {
      "id": "main_container",
      "component": "Column",
      "children": ["image_section", "content_section"],
      "align": "stretch"
    },
    {
      "id": "image_section",
      "component": "Column",
      "children": ["top_overlay", "image_gallery"],
      "align": "stretch"
    },
    {
      "id": "top_overlay",
      "component": "Row",
      "children": ["top_spacer", "fav_icon"],
      "align": "start",
      "justify": "end"
    },
    {
      "id": "top_spacer",
      "component": "Column",
      "weight": 1
    },
    {
      "id": "fav_icon",
      "component": "Button",
      "child": "fav_icon_image",
      "variant": "ghost"
    },
    {
      "id": "fav_icon_image",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/FavIcon/icon"
      },
      "variant": "icon"
    },
    {
      "id": "image_gallery",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/ImageList2GIS/list",
        "componentId": "image_item_template"
      },
      "align": "center"
    },
    {
      "id": "image_item_template",
      "component": "Image",
      "url": {
        "path": "imageSrc"
      },
      "variant": "mediumFeature",
      "fit": "cover"
    },
    {
      "id": "content_section",
      "component": "Column",
      "children": ["rank_tags_section", "avatar_comment", "info_section"],
      "align": "stretch"
    },
    {
      "id": "rank_tags_section",
      "component": "Row",
      "children": ["rank_info", "important_tags"],
      "align": "start"
    },
    {
      "id": "rank_info",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/NewRankInfoByTypeV2/text"
      },
      "variant": "body"
    },
    {
      "id": "important_tags",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/ImportantTags/list",
        "componentId": "tag_template"
      },
      "align": "start"
    },
    {
      "id": "tag_template",
      "component": "Text",
      "text": {
        "path": ""
      },
      "variant": "caption"
    },
    {
      "id": "avatar_comment",
      "component": "Column",
      "children": {
        "path": "@placeholder(dataPath)/AvatarComment/recommendReason",
        "componentId": "comment_item_template"
      },
      "align": "start"
    },
    {
      "id": "comment_item_template",
      "component": "Row",
      "children": ["comment_avatars", "comment_text"],
      "align": "start"
    },
    {
      "id": "comment_avatars",
      "component": "Row",
      "children": {
        "path": "users",
        "componentId": "avatar_template"
      },
      "align": "start"
    },
    {
      "id": "avatar_template",
      "component": "Image",
      "url": {
        "path": "avatar"
      },
      "variant": "avatar"
    },
    {
      "id": "comment_text",
      "component": "Text",
      "text": {
        "path": "text"
      },
      "variant": "caption"
    },
    {
      "id": "info_section",
      "component": "Column",
      "children": ["title_text", "desc_row"],
      "align": "start"
    },
    {
      "id": "title_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Title/text"
      },
      "variant": "h3"
    },
    {
      "id": "desc_row",
      "component": "Row",
      "children": ["rank_tag", "desc_info2", "desc_info3", "short_address", "desc_info4", "desc_info"],
      "align": "center"
    },
    {
      "id": "rank_tag",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/RankTag/text"
      },
      "variant": "caption"
    },
    {
      "id": "desc_info2",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo2/text"
      },
      "variant": "caption"
    },
    {
      "id": "desc_info3",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo3/text"
      },
      "variant": "caption"
    },
    {
      "id": "short_address",
      "component": "Row",
      "children": ["address_name", "address_distance"],
      "align": "center"
    },
    {
      "id": "address_name",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ShortAddress/name"
      },
      "variant": "caption"
    },
    {
      "id": "address_distance",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ShortAddress/distance"
      },
      "variant": "caption"
    },
    {
      "id": "desc_info4",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo4/text"
      },
      "variant": "caption"
    },
    {
      "id": "desc_info",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo/text"
      },
      "variant": "caption"
    }
  ]
}