{
    "components": [
        {
            "id": "root",
            "component": "Column",
            "children": [
                "headline_container",
                "lead",
                "card_list"
            ],
            "styles": {
                "padding": "20px 20px 20px 20px",
                "background-color": "#E8F4F8"
            }
        },
        {
            "id": "headline_container",
            "component": "Row",
            "children": [
                "left_content",
                "right_icon"
            ],
            "styles": {
                "margin": "0px 0px 20px 0px"
            },
            "align": "center",
            "justify": "spaceBetween"
        },
        {
            "id": "left_content",
            "component": "Row",
            "children": [
                "headline_icon",
                "headline"
            ],
            "styles": {
                "align-items": "center"
            }
        },
        {
            "id": "headline_icon",
            "component": "Image",
            "url": "https://gw.alicdn.com/imgextra/i3/O1CN013xmmDE1HxtsbUIjCi_!!6000000000825-2-tps-74-72.png",
            "styles": {
                "margin": "0px 16px 0px 0px"
            }
        },
        {
            "id": "headline",
            "component": "Text",
            "text": "@placeholder(headline)",
            "styles": {
                "font-size": "48px",
                "font-weight": "bold",
                "color": "#1A1A1A"
            }
        },
        {
            "id": "right_icon",
            "component": "Image",
            "url": "https://gw.alicdn.com/imgextra/i3/O1CN015UexxQ2351zFoW4tK_!!6000000007203-2-tps-164-106.png",
            "styles": {
                "width": "65px",
                "height": "42px"
            }
        },
        {
            "id": "lead",
            "component": "Text",
            "text": "@placeholder(lead)",
            "styles": {
                "font-size": "42px",
                "color": "#333333",
                "line-height": 1.2,
                "margin": "0px 0px 40px 0px"
            }
        },
        {
            "id": "card_list",
            "component": "List",
            "children": {
                "path": "@placeholder(cards)",
                "componentId": "cards"
            }
        },
        {
            "id": "cards",
            "component": "Row",
            "children": [
                "card_icon",
                "card_content"
            ],
            "styles": {
                "align-items": "flex-start"
            }
        },
        {
            "id": "card_icon",
            "component": "Image",
            "url": "https://gw.alicdn.com/imgextra/i3/O1CN01EJijFx29RN03O7Ser_!!6000000008064-2-tps-44-382.png",
            "styles": {
                "height": "100%",
                "margin": "0px 0px 0px 0px"
            }
        },
        {
            "id": "card_content",
            "component": "Card",
            "children": [
                "card_inner"
            ],
            "styles": {
                "background-color": "#FFFFFF",
                "border-radius": "32px",
                "padding": "40px 40px 40px 40px",
                "filter": "drop-shadow(0px 4px 16px rgba(0, 0, 0, 0.08))",
                "flex-grow": 1,
                "margin": "0px 10px 20px 10px"
            }
        },
        {
            "id": "card_inner",
            "component": "Column",
            "children": [
                "tag_container",
                "title",
                "content"
            ],
            "styles": {
                "padding": "25px 45px 35px 45px"
            }
        },
        {
            "id": "tag_container",
            "component": "Row",
            "children": [
                "tag"
            ],
            "styles": {
                "margin": "0px 0px 16px 0px"
            }
        },
        {
            "id": "tag",
            "component": "Text",
            "text": "@placeholder(tag)",
            "styles": {
                "font-size": "28px",
                "font-weight": "bold",
                "color": "#DABA94",
                "background-color": "#FBF6F1",
                "padding": "6px 18px 6px 18px",
                "border-radius": "20px"
            }
        },
        {
            "id": "title",
            "component": "Text",
            "text": "@placeholder(title)",
            "styles": {
                "font-size": "44px",
                "font-weight": "bold",
                "color": "#0E0C24",
                "margin": "0px 0px 20px 0px"
            }
        },
        {
            "id": "content",
            "component": "Text",
            "text": "@placeholder(content)",
            "styles": {
                "font-size": "36px",
                "color": "#666666",
                "line-height": 1.2
            }
        }
    ]
}