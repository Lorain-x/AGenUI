{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "child": "main_container"
    },
    {
      "id": "main_container",
      "component": "Column",
      "children": ["image_section", "content_section"],
      "align": "stretch"
    },
    {
      "id": "image_section",
      "component": "Column",
      "children": ["top_overlay", "image_gallery", "image_bottom_overlay"],
      "align": "stretch"
    },
    {
      "id": "top_overlay",
      "component": "Row",
      "children": ["rank_banner", "distance_tag", "top_spacer", "fav_icon"],
      "align": "start",
      "justify": "spaceBetween"
    },
    {
      "id": "rank_banner",
      "component": "Row",
      "children": ["rank_no", "rank_title"],
      "align": "center"
    },
    {
      "id": "rank_no",
      "component": "Text",
      "text": {
        "call": "formatString",
        "args": {
          "value": "${@placeholder(dataPath)/RankBanner/rankNo}"
        }
      },
      "variant": "h2"
    },
    {
      "id": "rank_title",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/RankBanner/rankTitle"
      },
      "variant": "body"
    },
    {
      "id": "distance_tag",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DistanceTag/text"
      },
      "variant": "caption"
    },
    {
      "id": "top_spacer",
      "component": "Column",
      "weight": 1
    },
    {
      "id": "fav_icon",
      "component": "Button",
      "child": "fav_icon_image",
      "variant": "ghost"
    },
    {
      "id": "fav_icon_image",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/FavIcon/icon"
      },
      "variant": "icon"
    },
    {
      "id": "image_gallery",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/ImageList2GIS/list",
        "componentId": "image_item_template"
      },
      "align": "center"
    },
    {
      "id": "image_item_template",
      "component": "Image",
      "url": {
        "path": "imageSrc"
      },
      "variant": "mediumFeature",
      "fit": "cover"
    },
    {
      "id": "image_bottom_overlay",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/AiAtomText_ebe52582/text"
      },
      "variant": "caption"
    },
    {
      "id": "content_section",
      "component": "Column",
      "children": ["tags_section", "avatar_comment", "score_section", "divider", "info_section"],
      "align": "stretch"
    },
    {
      "id": "tags_section",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/ImportantTags/tags",
        "componentId": "tag_template"
      },
      "align": "start"
    },
    {
      "id": "tag_template",
      "component": "Text",
      "text": {
        "path": ""
      },
      "variant": "caption"
    },
    {
      "id": "avatar_comment",
      "component": "Column",
      "children": {
        "path": "@placeholder(dataPath)/AvatarComment/recommendReason",
        "componentId": "comment_item_template"
      },
      "align": "start"
    },
    {
      "id": "comment_item_template",
      "component": "Row",
      "children": ["comment_avatars", "comment_text"],
      "align": "start"
    },
    {
      "id": "comment_avatars",
      "component": "Row",
      "children": {
        "path": "users",
        "componentId": "avatar_template"
      },
      "align": "start"
    },
    {
      "id": "avatar_template",
      "component": "Image",
      "url": {
        "path": "avatar"
      },
      "variant": "avatar"
    },
    {
      "id": "comment_text",
      "component": "Text",
      "text": {
        "path": "text"
      },
      "variant": "caption"
    },
    {
      "id": "score_section",
      "component": "Row",
      "children": ["score_value", "score_desc"],
      "align": "center"
    },
    {
      "id": "score_value",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ScoreBar/score"
      },
      "variant": "h2"
    },
    {
      "id": "score_desc",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ScoreBar/scoreDesc"
      },
      "variant": "caption"
    },
    {
      "id": "divider",
      "component": "Column"
    },
    {
      "id": "info_section",
      "component": "Column",
      "children": ["title_text", "desc_row"],
      "align": "start"
    },
    {
      "id": "title_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Title/text"
      },
      "variant": "h3"
    },
    {
      "id": "desc_row",
      "component": "Row",
      "children": ["desc_info2", "desc_info3", "short_address"],
      "align": "center"
    },
    {
      "id": "desc_info2",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo2/text"
      },
      "variant": "caption"
    },
    {
      "id": "desc_info3",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo3/text"
      },
      "variant": "caption"
    },
    {
      "id": "short_address",
      "component": "Row",
      "children": ["address_name", "address_distance"],
      "align": "center"
    },
    {
      "id": "address_name",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ShortAddress/name"
      },
      "variant": "caption"
    },
    {
      "id": "address_distance",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ShortAddress/distance"
      },
      "variant": "caption"
    }
  ]
}