{
  "components": [
    {
      "id": "root",
      "component": "Column",
      "children": [
        "header_container",
        "grid_container"
      ],
      "styles": {
        "padding": "16px 16px 16px 16px",
        "background-color": "#E8F4F8",
        "width": "100%"
      }
    },
    {
      "id": "header_container",
      "component": "Row",
      "children": [
        "left_content",
        "right_icon"
      ],
      "align": "center",
      "justify": "spaceBetween",
      "styles": {
        "margin": "16px 6px 16px 6px"
      }
    },
    {
      "id": "left_content",
      "component": "Row",
      "children": [
        "header_icon",
        "header_title"
      ],
      "styles": {
        "align-items": "center"
      }
    },
    {
      "id": "header_icon",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i3/O1CN01WtMphh1vr6dOuX3T2_!!6000000006225-2-tps-72-70.png",
      "styles": {
        "width": "48px",
        "height": "48px",
        "margin": "0px 8px 0px 0px"
      }
    },
    {
      "id": "header_title",
      "component": "Text",
      "text": "@placeholder(headline)",
      "styles": {
        "font-size": "44px",
        "font-weight": "bold",
        "color": "#0A0D35"
      }
    },
    {
      "id": "right_icon",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i3/O1CN015UexxQ2351zFoW4tK_!!6000000007203-2-tps-164-106.png",
      "styles": {
        "width": "65px",
        "height": "42px"
      }
    },
    {
      "id": "grid_container",
      "component": "Row",
      "children": {
        "path": "@placeholder(items)",
        "componentId": "info_card"
      },
      "styles": {
        "flex-wrap": "wrap",
        "width":"100%"
      },
      "justify": "spaceBetween"
    },
    {
      "id": "info_card",
      "component": "Card",
      "child": "card_content",
      "styles": {
        "flex-basis": "45%",
        "flex-grow": 1,
        "flex-shrink": 0,
        "margin": "12px 6px 0px 6px",
        "background-color": "#FFFFFF",
        "border-radius": "24px",
        "padding": "16px"
      }
    },
    {
      "id": "card_content",
      "component": "Column",
      "children": [
        "card_icon",
        "card_title",
        "card_divider",
        "card_description"
      ],
      "styles": {
        "padding": "32px"
      }
    },
    {
      "id": "card_icon",
      "component": "Image",
      "url": "@placeholder(url)",
      "styles": {
        "width": "60px",
        "height": "60px"
      },
      "fit": "fill"
    },
    {
      "id": "card_title",
      "component": "Text",
      "text": "@placeholder(title)",
      "styles": {
        "font-size": "42px",
        "font-weight": "bold",
        "color": "#1A1A1A",
        "margin": "16px 0px 0px 0px"
      }
    },
    {
      "id": "card_divider",
      "component": "Divider",
      "axis": "horizontal",
      "styles": {
        "margin": "16px 0px 16px 0px",
        "border-color": "#E5E5E5",
        "img": "https://gw.alicdn.com/imgextra/i3/O1CN01w6apVc23JEGULezum_!!6000000007234-2-tps-160-15.png",
        "thickness": "4px",
        "border-width": "1px"
      }
    },
    {
      "id": "card_description",
      "component": "Text",
      "text": "@placeholder(description)",
      "variant": "body",
      "styles": {
        "font-size": "34px",
        "color": "#666666",
        "line-height": 1.5
      }
    }
  ]
}