{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "children": [
        "card_content"
      ]
    },
    {
      "id": "card_content",
      "component": "Column",
      "children": [
        "first_row",
        "second_row",
        "third_row",
        "fourth_row"
      ]
    },
    {
      "id": "first_row",
      "component": "Row",
      "children": [
        "image",
        "detail_info",
        "action_text"
      ]
    },
    {
      "id": "image",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/image"
      }
    },
    {
      "id": "detail_info",
      "component": "Column",
      "children": [
        "title",
        "info_row"
      ]
    },
    {
      "id": "title",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/title"
      }
    },
    {
      "id": "info_row",
      "component": "Row",
      "children": [
        "rating",
        "time_info"
      ]
    },
    {
      "id": "rating",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/rating"
      }
    },
    {
      "id": "time_info",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/time_info"
      }
    },
    {
      "id": "action_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/action_text"
      }
    },
    {
      "id": "second_row",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/tags",
        "componentId": "tag_wrapper"
      }
    },
    {
      "id": "tag_wrapper",
      "component": "Text",
      "text": {
        "path": "tag"
      }
    },
    {
      "id": "third_row",
      "component": "Row",
      "children": [
        "product",
        "price"
      ]
    },
    {
      "id": "product",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/product"
      }
    },
    {
      "id": "price",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/price"
      }
    },
    {
      "id": "fourth_row",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/highlights"
      }
    }
  ]
}