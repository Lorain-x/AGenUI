{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "children": [
        "card_content"
      ],
      "styles": {
        "background-color": "#EDECED",
        "border-radius": "32px",
        "margin": "0px 30px 30px 30px"
      }
    },
    {
      "id": "card_content",
      "component": "Column",
      "children": [
        "icon",
        "title",
        "content"
      ],
      "justify": "center",
      "align": "center",
      "styles": {
        "padding": "32px"
      }
    },
    {
      "id": "icon",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i3/O1CN01duZUlB1Z0y007kY5I_!!6000000003133-2-tps-118-98.png",
      "styles": {
        "margin": "0px 0px 20px 0px"
      }
    },
    {
      "id": "title",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/quotetitle"
      },
      "styles": {
        "font-size": "48px",
        "font-weight": "bold",
        "color": "#CAA266",
        "margin": "0px 0px 30px 0px"
      }
    },
    {
      "id": "content",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/quotecontent"
      },
      "styles": {
        "font-size": "42px",
        "color": "#313347",
        "font-weight": "bold",
        "line-height": 1.2,
        "text-align": "center",
        "padding": "0px 65px 0px 65px"
      }
    }
  ]
}