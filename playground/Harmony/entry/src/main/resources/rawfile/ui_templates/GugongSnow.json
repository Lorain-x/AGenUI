{
  "components": [
      {
        "align": "stretch",
        "children": [
          "route_section"
        ],
        "component": "Column",
        "id": "root"
      },
      {
        "child": "route_inner_layout",
        "component": "Card",
        "id": "route_section"
      },
      {
        "children": [
          "route_title",
          "route_meta",
          "route_list"
        ],
        "component": "Column",
        "id": "route_inner_layout"
      },
      {
        "component": "Text",
        "id": "route_title",
        "text": "@placeholder(routeTitle)",
        "variant": "h2"
      },
      {
        "component": "Text",
        "id": "route_meta",
        "text": "@placeholder(routeMeta)",
        "variant": "caption"
      },
      {
        "children": {
          "path": "@placeholder(routeTimeLineListPath)",
          "componentId": "timeline_item"
        },
        "component": "Column",
        "id": "route_list"
      },
      {
        "align": "start",
        "children": [
          "timeline_icon_col",
          "timeline_content_col"
        ],
        "component": "Row",
        "id": "timeline_item"
      },
      {
        "align": "center",
        "children": [
          "timeline_icon"
        ],
        "component": "Column",
        "id": "timeline_icon_col"
      },
      {
        "component": "Text",
        "id": "timeline_icon",
        "text": "⬇️",
        "variant": "caption"
      },
      {
        "children": [
          "tl_station",
          "tl_desc"
        ],
        "component": "Column",
        "id": "timeline_content_col"
      },
      {
        "component": "Text",
        "id": "tl_station",
        "text": "@placeholder(routeStationName)",
        "variant": "h3"
      },
      {
        "component": "Text",
        "id": "tl_desc",
        "text": "@placeholder(routeStationDesc)",
        "variant": "body"
      }
    ]
}
