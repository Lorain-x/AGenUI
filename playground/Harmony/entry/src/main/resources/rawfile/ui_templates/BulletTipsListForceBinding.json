{
  "components": [
    {
      "id": "root",
      "component": "Column",
      "children": [
        "headline_container",
        "lead",
        "tips_list"
      ],
      "styles": {
        "background-color": "#E8F4F8",
        "padding": "10px 10px 10px 10px",
        "margin": "0px 30px 20px 30px"
      }
    },
    {
      "id": "headline_container",
      "component": "Row",
      "children": [
        "left_content",
        "right_icon"
      ],
      "styles": {
        "margin": "0px 0px 10px 0px"
      },
      "align": "center",
      "justify": "spaceBetween"
    },
    {
      "id": "left_content",
      "component": "Row",
      "children": [
        "headline_icon",
        "headline"
      ],
      "styles": {
        "align-items": "center"
      },
      "align": "center",
      "justify": "center"
    },
    {
      "id": "headline_icon",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i1/O1CN01rD0f3C1xFD5wdozeN_!!6000000006413-2-tps-52-54.png",
      "styles": {
        "margin": "0px 16px 0px 0px"
      }
    },
    {
      "id": "headline",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/tipsheadline"
      },
      "styles": {
        "font-size": "54px",
        "font-weight": "bold",
        "color": "#1A1A1A"
      }
    },
    {
      "id": "right_icon",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i3/O1CN015UexxQ2351zFoW4tK_!!6000000007203-2-tps-164-106.png",
      "styles": {
        "width": "65px",
        "height": "42px"
      }
    },
    {
      "id": "lead",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/tipslead"
      },
      "styles": {
        "font-size": "46px",
        "line-height": 1.5,
        "margin": "10px 0px 40px 0px"
      }
    },
    {
      "id": "tips_list",
      "component": "List",
      "children": {
        "path": "@placeholder(dataPath)/tipscards",
        "componentId": "tip"
      }
    },
    {
      "id": "tip",
      "component": "Row",
      "children": [
        "text_content"
      ],
      "styles": {
        "margin": "0px 0px 32px 0px"
      }
    },
    {
      "id": "text_content",
      "component": "RichText",
      "text": {
        "path": "text"
      },
      "styles": {
        "fontSize": 13,
        "color": "#1A1A1A",
        "line-height": 1.5
      }
    }
  ]
}