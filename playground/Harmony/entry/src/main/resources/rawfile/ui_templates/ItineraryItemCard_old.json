{
    "components": [
        {
            "id": "root",
            "component": "Card",
            "children": [
                "card_content"
            ]
        },
        {
            "id": "card_content",
            "component": "Column",
            "children": [
                "first_row",
                "second_row",
                "third_row",
                "fourth_row"
            ]
        },
        {
            "id": "first_row",
            "component": "Row",
            "children": [
                "image",
                "detail_info",
                "action_text"
            ]
        },
        {
            "id": "image",
            "component": "Image",
            "url": "@placeholder(image)"
        },
        {
            "id": "detail_info",
            "component": "Column",
            "children": [
                "title",
                "info_row"
            ]
        },
        {
            "id": "title",
            "component": "Text",
            "text": "@placeholder(title)"
        },
        {
            "id": "info_row",
            "component": "Row",
            "children": [
                "rating",
                "time_info"
            ]
        },
        {
            "id": "rating",
            "component": "Text",
            "text": "@placeholder(rating)"
        },
        {
            "id": "time_info",
            "component": "Text",
            "text": "@placeholder(time_info)"
        },
        {
            "id": "action_text",
            "component": "Text",
            "text": "@placeholder(action_text)"
        },
        {
            "id": "second_row",
            "component": "Row",
            "children": {
                "path": "@placeholder(tags)",
                "componentId": "tag_wrapper"
            }
        },
        {
            "id": "tag_wrapper",
            "component": "Text",
            "text": "@placeholder(tag)"
        },
        {
            "id": "third_row",
            "component": "Row",
            "children": [
                "product",
                "price"
            ]
        },
        {
            "id": "product",
            "component": "Text",
            "text": "@placeholder(product)"
        },
        {
            "id": "price",
            "component": "Text",
            "text": "@placeholder(price)"
        },
        {
            "id": "fourth_row",
            "component": "Text",
            "text": "@placeholder(highlights)"
        }
    ]
}
