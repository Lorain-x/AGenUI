{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "child": "main_container"
    },
    {
      "id": "main_container",
      "component": "Row",
      "children": [
        "image_section",
        "content_section"
      ],
      "align": "start"
    },
    {
      "id": "image_section",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/Media/imgSrc"
      },
      "variant": "mediumFeature",
      "fit": "cover"
    },
    {
      "id": "content_section",
      "component": "Column",
      "children": [
        "title_text",
        "tags_row",
        "bottom_row"
      ],
      "justify": "spaceBetween",
      "align": "stretch",
      "weight": 1
    },
    {
      "id": "title_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Title/text"
      },
      "variant": "body"
    },
    {
      "id": "tags_row",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/AttrTags/textList",
        "componentId": "tag_template"
      },
      "align": "start"
    },
    {
      "id": "tag_template",
      "component": "Text",
      "text": {
        "path": "."
      },
      "variant": "caption"
    },
    {
      "id": "bottom_row",
      "component": "Row",
      "children": [
        "price_section",
        "action_section"
      ],
      "justify": "spaceBetween",
      "align": "end"
    },
    {
      "id": "price_section",
      "component": "Column",
      "children": [
        "price_row",
        "sales_info"
      ],
      "align": "start"
    },
    {
      "id": "price_row",
      "component": "Row",
      "children": [
        "current_price",
        "original_price"
      ],
      "align": "end"
    },
    {
      "id": "current_price",
      "component": "Text",
      "text": {
        "call": "formatString",
        "args": {
          "value": "${@placeholder(dataPath)/PriceInfo2/prefix}${@placeholder(dataPath)/PriceInfo2/text}"
        }
      },
      "variant": "h3"
    },
    {
      "id": "original_price",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/OriginPrice2/text"
      },
      "variant": "caption"
    },
    {
      "id": "sales_info",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/SalesInfo/text"
      },
      "variant": "caption"
    },
    {
      "id": "action_section",
      "component": "Button",
      "child": "button_label",
      "variant": "primary",
      "action": {
        "functionCall": {
          "call": "openUrl",
          "args": {
            "url": {
              "path": "@placeholder(dataPath)/ButtonInfo/schema"
            }
          }
        }
      }
    },
    {
      "id": "button_label",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ButtonInfo/text"
      }
    }
  ]
}