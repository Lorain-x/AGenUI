{
  "components": [
    {
      "id": "root",
      "component": "Column",
      "children": [
        "headline_container",
        "subtitle",
        "divider",
        "image",
        "main_content"
      ],
      "styles": {
        "margin": "30px 30px 0px 30px",
        "background-color": "#E8F4F8"
      }
    },
    {
      "id": "headline_container",
      "component": "Row",
      "children": [
        "headline"
      ],
      "styles": {
        "align-items": "center",
        "flex-wrap": "wrap"
      }
    },
    {
      "id": "headline",
      "component": "RichText",
      "text": {
        "path": "@placeholder(dataPath)/descheadline"
      },
      "styles": {
        "font-size": "60px",
        "font-weight": "bold",
        "color": "#05163B",
        "margin": "0px 8px -50px 0px"
      }
    },
    {
      "id": "subtitle",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/descsubtitle"
      },
      "styles": {
        "font-size": "34px",
        "color": "#999999",
        "margin": "0px 0px 32px 0px"
      }
    },
    {
      "id": "divider",
      "component": "Divider",
      "styles": {
        "margin": "0px 0px 40px 0px",
        "background-color": "#FFFFFFFF",
        "img": "https://gw.alicdn.com/imgextra/i2/O1CN01nr2Cel1dHEWrbaEFB_!!6000000003710-2-tps-160-34.png",
        "thickness": "10px"
      }
    },
    {
      "id": "image",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/descimage"
      },
      "styles": {
        "width": "100%",
        "height": "360px",
        "border-radius": "32px",
        "margin": "0px 0px 40px 0px"
      },
      "fit": "fill"
    },
    {
      "id": "main_content",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/descbody"
      },
      "styles": {
        "font-size": "44px",
        "color": "#0C0F28",
        "line-height": 1.3
      }
    }
  ]
}