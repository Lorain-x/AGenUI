{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "child": "main_container"
    },
    {
      "id": "main_container",
      "component": "Row",
      "children": ["image_section", "content_section"],
      "align": "start"
    },
    {
      "id": "image_section",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/Media/imgSrc"
      },
      "variant": "mediumFeature",
      "fit": "cover"
    },
    {
      "id": "content_section",
      "component": "Column",
      "children": ["title_row", "desc_row", "rating_row", "tag_row", "promo_section"],
      "justify": "spaceBetween",
      "align": "stretch",
      "weight": 1
    },
    {
      "id": "title_row",
      "component": "Row",
      "children": ["title_text", "title_icon", "title_tag"],
      "align": "center"
    },
    {
      "id": "title_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Title/text"
      },
      "variant": "h3"
    },
    {
      "id": "title_icon",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/TitleIcon/icon"
      },
      "variant": "icon"
    },
    {
      "id": "title_tag",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/TitleTag/text"
      },
      "variant": "caption"
    },
    {
      "id": "desc_row",
      "component": "Row",
      "children": ["desc_info", "spacer", "distance"],
      "justify": "spaceBetween",
      "align": "center"
    },
    {
      "id": "desc_info",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo/text"
      },
      "variant": "caption"
    },
    {
      "id": "spacer",
      "component": "Column",
      "weight": 1
    },
    {
      "id": "distance",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Distance/text"
      },
      "variant": "caption"
    },
    {
      "id": "rating_row",
      "component": "Row",
      "children": ["score", "category_text", "goods_desc"],
      "align": "center"
    },
    {
      "id": "score",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Score2/score"
      },
      "variant": "body"
    },
    {
      "id": "category_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/CategoryText/text"
      },
      "variant": "caption"
    },
    {
      "id": "goods_desc",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/GoodsDesc/text"
      },
      "variant": "caption"
    },
    {
      "id": "tag_row",
      "component": "Row",
      "children": ["rank_tag", "category_tag"],
      "align": "center"
    },
    {
      "id": "rank_tag",
      "component": "Row",
      "children": ["rank_icon", "rank_text"],
      "align": "center"
    },
    {
      "id": "rank_icon",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/ImageRankTag/icon"
      },
      "variant": "icon"
    },
    {
      "id": "rank_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ImageRankTag/rightText"
      },
      "variant": "caption"
    },
    {
      "id": "category_tag",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Category/text"
      },
      "variant": "caption"
    },
    {
      "id": "promo_section",
      "component": "Row",
      "children": ["group_icon", "price_info", "desc_text", "promo_spacer", "action_text"],
      "align": "center",
      "justify": "spaceBetween"
    },
    {
      "id": "group_icon",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/GroupIcon/icon"
      },
      "variant": "icon"
    },
    {
      "id": "price_info",
      "component": "Text",
      "text": {
        "call": "formatString",
        "args": {
          "value": "${@placeholder(dataPath)/PriceInfo/prefix}${@placeholder(dataPath)/PriceInfo/text}${@placeholder(dataPath)/PriceInfo/suffix}"
        }
      },
      "variant": "h3"
    },
    {
      "id": "desc_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescText/text"
      },
      "variant": "caption"
    },
    {
      "id": "promo_spacer",
      "component": "Column",
      "weight": 1
    },
    {
      "id": "action_text",
      "component": "Row",
      "children": ["action_label", "action_icon"],
      "align": "center"
    },
    {
      "id": "action_label",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ImageIconText/text"
      },
      "variant": "body"
    },
    {
      "id": "action_icon",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/ImageIconText/rightImageSrc"
      },
      "variant": "icon"
    }
  ]
}