{
  "components": [
    {
      "id": "root",
      "component": "Column",
      "children": [
        "headline_container",
        "lead",
        "box_list"
      ],
      "styles": {
        "padding": "20px 20px 20px 20px",
        "background-color": "#E8F4F8"
      }
    },
    {
      "id": "headline_container",
      "component": "Row",
      "children": [
        "left_content",
        "right_icon"
      ],
      "styles": {
        "margin": "0px 0px 32px 0px"
      },
      "align": "center",
      "justify": "spaceBetween"
    },
    {
      "id": "left_content",
      "component": "Row",
      "children": [
        "left_icon",
        "headline"
      ],
      "styles": {
        "align-items": "center"
      }
    },
    {
      "id": "left_icon",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i1/O1CN01n5rDkk1hlhKxUHGcZ_!!6000000004318-2-tps-110-112.png",
      "styles": {
        "width": "48px",
        "height": "48px",
        "margin": "0px 16px 0px 0px"
      }
    },
    {
      "id": "headline",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/reasonheadline"
      },
      "styles": {
        "font-size": "50px",
        "font-weight": "bold",
        "color": "#0E142B"
      }
    },
    {
      "id": "right_icon",
      "component": "Image",
      "url": "https://gw.alicdn.com/imgextra/i3/O1CN015UexxQ2351zFoW4tK_!!6000000007203-2-tps-164-106.png",
      "styles": {
        "width": "65px",
        "height": "42px"
      }
    },
    {
      "id": "lead",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/reasonlead"
      },
      "styles": {
        "font-size": "42px",
        "color": "#0E142B",
        "line-height": 1.3,
        "margin": "0px 0px 40px 0px"
      }
    },
    {
      "id": "box_list",
      "component": "List",
      "children": {
        "path": "@placeholder(dataPath)/reasoncards",
        "componentId": "cards"
      }
    },
    {
      "id": "cards",
      "component": "Card",
      "children": [
        "card_wrapper"
      ],
      "styles": {
        "background-color": "#FFFFFF",
        "border-radius": "32px",
        "margin": "0px 10px 32px 10px",
        "filter": "drop-shadow(0px 4px 16px rgba(0, 0, 0, 0.08))"
      }
    },
    {
      "id": "card_wrapper",
      "component": "Column",
      "children": [
        "title_container",
        "content"
      ],
      "styles": {
        "padding": "32px 32px 32px 32px"
      }
    },
    {
      "id": "title_container",
      "component": "Row",
      "children": [
        "title"
      ],
      "styles": {
        "margin": "0px 0px 32px 0px"
      }
    },
    {
      "id": "title",
      "component": "Text",
      "text": {
        "path": "title"
      },
      "styles": {
        "font-size": "36px",
        "font-weight": "bold",
        "color": "#FFFFFF",
        "background-color": "#E8A865",
        "padding": "6px 18px 6px 18px",
        "border-radius": "40px"
      }
    },
    {
      "id": "content",
      "component": "Text",
      "text": {
        "path": "content"
      },
      "styles": {
        "font-size": "46px",
        "color": "#353341",
        "line-height": "1.3"
      }
    }
  ]
}