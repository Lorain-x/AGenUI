{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "child": "main_container",
      "action": {
        "functionCall": {
          "call": "openUrl",
          "args": {
            "url": {
              "path": "@placeholder(dataPath)/Link/schema"
            }
          }
        }
      }
    },
    {
      "id": "main_container",
      "component": "Column",
      "children": [
        "image_list",
        "content_section"
      ],
      "align": "stretch"
    },
    {
      "id": "image_list",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/ImageList2GIS/list",
        "componentId": "image_template"
      },
      "align": "start"
    },
    {
      "id": "image_template",
      "component": "Image",
      "url": {
        "path": "."
      },
      "variant": "mediumFeature",
      "fit": "cover"
    },
    {
      "id": "content_section",
      "component": "Column",
      "children": [
        "rank_badge",
        "title_row",
        "address_row",
        "info_row",
        "tags_row"
      ],
      "align": "stretch"
    },
    {
      "id": "rank_badge",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/ImageRankNo/rankNo"
      },
      "variant": "caption"
    },
    {
      "id": "title_row",
      "component": "Row",
      "children": [
        "title_text",
        "navigation_icon"
      ],
      "justify": "spaceBetween",
      "align": "center"
    },
    {
      "id": "title_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/TitleLeft/text"
      },
      "variant": "h3"
    },
    {
      "id": "navigation_icon",
      "component": "Button",
      "child": "nav_label",
      "variant": "text",
      "action": {
        "functionCall": {
          "call": "openUrl",
          "args": {
            "url": {
              "path": "@placeholder(dataPath)/NavigationIcon/schema"
            }
          }
        }
      }
    },
    {
      "id": "nav_label",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/NavigationIcon/text"
      },
      "variant": "caption"
    },
    {
      "id": "address_row",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/AddressSimpleLeft/name"
      },
      "variant": "caption"
    },
    {
      "id": "info_row",
      "component": "Row",
      "children": [
        "score_text",
        "desc_info",
        "desc_info4"
      ],
      "align": "center"
    },
    {
      "id": "score_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/Score/text"
      },
      "variant": "body"
    },
    {
      "id": "desc_info",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo/text"
      },
      "variant": "caption"
    },
    {
      "id": "desc_info4",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/DescInfo4/text"
      },
      "variant": "caption"
    },
    {
      "id": "tags_row",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/OpenTags/list",
        "componentId": "tag_template"
      },
      "align": "start"
    },
    {
      "id": "tag_template",
      "component": "Text",
      "text": {
        "path": "."
      },
      "variant": "caption"
    }
  ]
}