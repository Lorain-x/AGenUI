      },
      "variant": "caption"
    },
    {
      "id": "price_info",
      "component": "Text",
      "text": {
        "call": "formatString",
        "args": {
          "value": "${@placeholder(dataPath)/AiAtomPrice_7a31d9bf/text}${@placeholder(dataPath)/AiAtomPrice_7a31d9bf/suffix}"
        }
      },
      "variant": "body"
    },
    {
      "id": "action_section",
      "component": "Button",
      "child": "button_label",
      "variant": "secondary"
    },
    {
      "id": "button_label",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/AiAtomButton_fb325bb9/text"
      }
