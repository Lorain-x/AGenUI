    {
      "id": "title_text",
      "component": "Text",
      "text": {
        "path": "@placeholder(dataPath)/TextTag/text"
      },
      "variant": "h3"
    },
    {
      "id": "info_list",
      "component": "Column",
      "children": {
        "path": "@placeholder(dataPath)/AiAtomListText_c7178a88/textList",
