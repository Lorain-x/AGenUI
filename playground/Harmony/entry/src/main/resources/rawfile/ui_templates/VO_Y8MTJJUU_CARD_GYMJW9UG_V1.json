{
  "components": [
    {
      "id": "root",
      "component": "Card",
      "child": "main_container"
    },
    {
      "id": "main_container",
      "component": "Row",
      "children": ["image_section", "content_section", "action_section"],
      "align": "start",
      "justify": "spaceBetween"
    },
    {
      "id": "image_section",
      "component": "Image",
      "url": {
        "path": "@placeholder(dataPath)/AiAtomImage_4aceb5f2/imgSrc"
      },
      "variant": "mediumFeature",
      "fit": "cover"
    },
    {
      "id": "content_section",
      "component": "Column",
      "children": ["title_text", "info_list", "bottom_row"],
      "align": "stretch",
      "weight": 1
