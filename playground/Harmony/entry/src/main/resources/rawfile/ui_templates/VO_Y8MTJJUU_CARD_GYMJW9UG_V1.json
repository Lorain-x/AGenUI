      },
      "align": "center"
    },
    {
      "id": "charge_pile_template",
      "component": "Row",
      "children": ["charge_type", "charge_status"],
      "align": "center"
    },
    {
      "id": "charge_type",
      "component": "Text",
      "text": {
        "path": "chargeTag/fullTypeText"
