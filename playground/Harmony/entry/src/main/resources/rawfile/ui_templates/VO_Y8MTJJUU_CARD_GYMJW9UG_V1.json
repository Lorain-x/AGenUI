      },
      "align": "start"
    },
    {
      "id": "info_item_template",
      "component": "Text",
      "text": {
        "path": ""
      },
      "variant": "caption"
    },
    {
      "id": "bottom_row",
      "component": "Row",
      "children": ["charge_pile_info", "price_info"],
      "align": "center"
    },
    {
      "id": "charge_pile_info",
      "component": "Row",
      "children": {
        "path": "@placeholder(dataPath)/AiAtomChargePileInfo_0d84a822/list",
